# API Configuration - use .env.development / .env.production (never commit secrets)
VITE_API_URL=

# Server origin without /api — uploads, Socket.IO, assets
VITE_SERVER_URL=

# Optional: WebSocket origin (defaults to ws/wss from VITE_SERVER_URL)
# VITE_WS_URL=

# Optional: SEO SSR host for Vercel rewrite (scripts/write-vercel-json.mjs at build)
# VITE_SEO_SSR_URL=
