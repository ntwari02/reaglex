# API Configuration - override in .env.development (localhost) or .env.production
# Local dev:  VITE_API_URL=http://localhost:5000/api
# Production: VITE_API_URL=https://reaglex.onrender.com/api
VITE_API_URL=

# Server URL (uploads, WebSocket) - usually same as API base without /api
VITE_SERVER_URL=

# Optional: WebSocket URL (defaults to VITE_SERVER_URL with ws/wss)
# VITE_WS_URL=
